<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Seed Summary · {{ generated_at }}</title>
<style>
  :root { --bg:#0f1115; --card:#171a21; --line:#262b36; --txt:#e7eaf0; --mut:#9aa3b2; --accent:#7c9cff; }
  * { box-sizing:border-box; }
  body { font-family:-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif; background:var(--bg); color:var(--txt); margin:0; }
  header { padding:22px 20px; border-bottom:1px solid var(--line); position:sticky; top:0; background:var(--bg); z-index:10; }
  h1 { margin:0; font-size:20px; }
  .sub { color:var(--mut); font-size:13px; margin-top:4px; }
  .bar { display:flex; gap:10px; flex-wrap:wrap; align-items:center; margin-top:12px; }
  .bar input, .bar select { background:var(--card); color:var(--txt); border:1px solid var(--line); border-radius:8px; padding:7px 10px; font-size:13px; }
  .btn { background:var(--accent); color:#0f1115; border:none; border-radius:8px; padding:9px 14px; font-weight:700; cursor:pointer; font-size:13px; }
  .btn.ghost { background:transparent; color:var(--accent); border:1px solid var(--accent); }
  main { padding:18px 20px 80px; max-width:980px; margin:0 auto; }
  .card { background:var(--card); border:1px solid var(--line); border-radius:12px; padding:14px 16px; margin-bottom:12px; display:grid; grid-template-columns:28px 1fr auto; gap:12px; align-items:start; }
  .chk { margin-top:4px; transform:scale(1.3); accent-color:var(--accent); }
  .name { font-size:16px; font-weight:700; }
  .score { font-weight:800; padding:3px 10px; border-radius:14px; background:#20283f; color:var(--accent); font-size:13px; white-space:nowrap; }
  .score.hi { background:#143524; color:#5fd68b; }
  .tags { margin:6px 0; }
  .tag { display:inline-block; font-size:11px; padding:2px 8px; border-radius:10px; margin:2px 5px 2px 0; }
  .tag.dom { background:#3a2a12; color:#f2b25c; }
  .tag.ai { background:#2b2150; color:#b6a4ff; }
  .tag.stage { background:#12303a; color:#62c6e6; }
  .meta { color:var(--mut); font-size:12px; }
  .jobs { margin:8px 0 0; padding:0; list-style:none; }
  .jobs li { font-size:13px; padding:3px 0; }
  .jobs a { color:var(--accent); text-decoration:none; }
  .blurb { color:#c4ccd9; font-size:13px; margin-top:6px; }
  .footerbar { position:fixed; bottom:0; left:0; right:0; background:#0b0d11; border-top:1px solid var(--line); padding:12px 20px; display:flex; justify-content:space-between; align-items:center; }
  .count { color:var(--mut); font-size:13px; }
  a.src { color:var(--mut); font-size:12px; }
  .empty { color:var(--mut); text-align:center; padding:40px; }
</style>
</head>
<body>
<header>
  <h1>🌱 Seed Summary</h1>
  <div class="sub">Week of {{ generated_at }} · {{ companies|length }} companies · select any to add to your watchlist</div>
  <div class="bar">
    <input id="q" type="search" placeholder="Filter by name, domain, investor…" oninput="render()">
    <select id="filter" onchange="render()">
      <option value="all">All</option>
      <option value="highlighted">High priority</option>
      <option value="hasjobs">Has matching roles</option>
      <option value="watch">Suggested to watch</option>
      <option value="ai">AI companies</option>
    </select>
    <select id="sort" onchange="render()">
      <option value="score">Sort: score</option>
      <option value="name">Sort: name</option>
      <option value="recent">Sort: most recent</option>
    </select>
  </div>
</header>
<main id="list"></main>
<div class="footerbar">
  <span class="count"><span id="selcount">0</span> selected</span>
  <div>
    <button class="btn ghost" onclick="selectAll()">Select all visible</button>
    <button class="btn" onclick="saveWatchlist()">⭐ Save to watchlist</button>
  </div>
</div>

<script id="payload" type="application/json">{{ payload_json|safe }}</script>
<script>
  const REPO = "{{ repo }}";
  const DATA = JSON.parse(document.getElementById('payload').textContent);
  const selected = new Set();

  function tag(t, cls){ return `<span class="tag ${cls}">${t}</span>`; }

  function matches(c){
    const q = document.getElementById('q').value.toLowerCase().trim();
    const f = document.getElementById('filter').value;
    if (f === 'highlighted' && !c.highlighted) return false;
    if (f === 'hasjobs' && !(c.matched_jobs||[]).length) return false;
    if (f === 'watch' && !c.suggest_watch) return false;
    if (f === 'ai' && !c.ai_signal) return false;
    if (!q) return true;
    const hay = [c.name, (c.domains||[]).join(' '), (c.investors||[]).join(' '), c.blurb].join(' ').toLowerCase();
    return hay.includes(q);
  }

  function sortKey(list){
    const s = document.getElementById('sort').value;
    if (s === 'name') return list.sort((a,b)=>a.name.localeCompare(b.name));
    if (s === 'recent') return list.sort((a,b)=>(b.funded_on||'').localeCompare(a.funded_on||''));
    return list.sort((a,b)=>b.score-a.score);
  }

  function render(){
    const host = document.getElementById('list');
    let list = DATA.companies.filter(matches);
    list = sortKey(list);
    if (!list.length){ host.innerHTML = '<div class="empty">No companies match your filters.</div>'; return; }
    host.innerHTML = list.map(c => {
      const checked = selected.has(c.slug) ? 'checked' : '';
      const jobs = (c.matched_jobs||[]).map(j =>
        `<li>✅ <a href="${j.url}" target="_blank" rel="noopener">${j.title}</a> <span class="meta">· ${j.matched_role||''} · ${j.location||''}</span></li>`
      ).join('');
      const tags = [
        c.stage ? tag(c.stage, 'stage') : '',
        ...(c.domains||[]).map(d=>tag(d,'dom')),
        c.ai_signal ? tag('AI','ai') : ''
      ].join('');
      const src = (c.urls||[])[0] ? `<a class="src" href="${c.urls[0]}" target="_blank" rel="noopener">source ↗</a>` : '';
      return `<div class="card">
        <input class="chk" type="checkbox" ${checked} onchange="toggle('${c.slug}')">
        <div>
          <div class="name">${c.name}</div>
          <div class="tags">${tags}</div>
          <div class="meta">${c.amount||''} ${ (c.investors||[]).length ? '· '+c.investors.join(', ') : ''}</div>
          ${c.blurb ? `<div class="blurb">${c.blurb.slice(0,240)}</div>`:''}
          ${jobs ? `<ul class="jobs">${jobs}</ul>` : (c.suggest_watch ? '<div class="meta">No matching roles yet — hiring often lags funding.</div>':'')}
          ${src}
        </div>
        <div class="score ${c.highlighted?'hi':''}">${c.score}</div>
      </div>`;
    }).join('');
  }

  function toggle(slug){
    selected.has(slug) ? selected.delete(slug) : selected.add(slug);
    document.getElementById('selcount').textContent = selected.size;
  }
  function selectAll(){
    DATA.companies.filter(matches).forEach(c=>selected.add(c.slug));
    document.getElementById('selcount').textContent = selected.size;
    render();
  }

  function saveWatchlist(){
    if (!selected.size){ alert('Select at least one company first.'); return; }
    const picks = DATA.companies.filter(c=>selected.has(c.slug));
    const lines = picks.map(c => `- slug: ${c.slug}\n  name: ${c.name}\n  ats: {provider: ${ (c.ats&&c.ats.provider)||'' }, token: ${ (c.ats&&c.ats.token)||'' }}`);
    const body = [
      'Add these companies to my seed-summary watchlist:',
      '',
      '```yaml',
      ...lines,
      '```',
      '',
      '_Submitted from the dashboard. The `watchlist-update` workflow will merge these into config/watchlist.yml._'
    ].join('\n');
    const url = `https://github.com/${REPO}/issues/new`
      + `?title=${encodeURIComponent('[watchlist] add '+picks.length+' companies')}`
      + `&labels=${encodeURIComponent('watchlist')}`
      + `&body=${encodeURIComponent(body)}`;
    window.open(url, '_blank', 'noopener');
  }

  render();
</script>
</body>
</html>
