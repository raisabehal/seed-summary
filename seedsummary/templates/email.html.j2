<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
  body { font-family: -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif; color: #1a1a1a; background:#f6f7f9; margin:0; padding:0; }
  .wrap { max-width: 680px; margin: 0 auto; padding: 24px; }
  h1 { font-size: 22px; margin: 0 0 4px; }
  .sub { color:#666; font-size: 13px; margin-bottom: 20px; }
  .card { background:#fff; border:1px solid #e6e8eb; border-radius:10px; padding:16px; margin-bottom:14px; }
  .rank { display:inline-block; min-width:28px; font-weight:700; color:#5b6470; }
  .name { font-size:17px; font-weight:700; }
  .score { float:right; font-weight:700; padding:2px 10px; border-radius:14px; background:#eef2ff; color:#3949ab; font-size:13px; }
  .score.hi { background:#e7f6ec; color:#1b7f3b; }
  .meta { color:#555; font-size:13px; margin:6px 0; }
  .tag { display:inline-block; font-size:11px; padding:2px 8px; border-radius:10px; margin-right:5px; }
  .tag.dom { background:#fff3e0; color:#b45309; }
  .tag.ai { background:#ede9fe; color:#6d28d9; }
  .tag.stage { background:#e0f2fe; color:#0369a1; }
  .jobs { margin:8px 0 0; padding:0; list-style:none; }
  .jobs li { font-size:13px; padding:3px 0; border-top:1px dashed #eee; }
  .jobs a { color:#1f5fbf; text-decoration:none; }
  .new { background:#fde68a; color:#92400e; font-size:10px; padding:1px 5px; border-radius:6px; margin-left:6px; }
  .section-title { font-size:14px; text-transform:uppercase; letter-spacing:.04em; color:#8a929c; margin:26px 0 10px; }
  .cta { display:block; text-align:center; background:#3949ab; color:#fff !important; text-decoration:none; padding:12px; border-radius:8px; font-weight:700; margin:8px 0 24px; }
  .blurb { color:#444; font-size:13px; margin-top:6px; }
  .footer { color:#9aa1aa; font-size:12px; text-align:center; margin-top:18px; }
  .small { color:#888; font-size:12px; }
</style>
</head>
<body>
<div class="wrap">
  <h1>🌱 Seed Summary — week of {{ generated_at }}</h1>
  <div class="sub">{{ companies|length }} newly funded companies matched · {{ highlighted|length }} high-priority · {{ watchlist_updates|length }} watchlist updates</div>

  {% if dashboard_url %}
  <a class="cta" href="{{ dashboard_url }}">⭐ Open dashboard to pick companies to monitor →</a>
  {% endif %}

  {% if watchlist_updates %}
  <div class="section-title">📌 Your watchlist — new this week</div>
  {% for c in watchlist_updates %}
    <div class="card">
      <span class="score {% if c.highlighted %}hi{% endif %}">{{ c.score }}</span>
      <span class="name">{{ c.name }}</span>
      <div class="meta">
        {% if c.stage %}<span class="tag stage">{{ c.stage|title }}</span>{% endif %}
        {% for d in c.domains %}<span class="tag dom">{{ d }}</span>{% endfor %}
        {% if c.ai_signal %}<span class="tag ai">AI</span>{% endif %}
      </div>
      {% if c.new_jobs %}
      <ul class="jobs">
        {% for j in c.new_jobs %}
        <li><a href="{{ j.url }}">{{ j.title }}</a> <span class="small">{{ j.location }}</span><span class="new">NEW</span></li>
        {% endfor %}
      </ul>
      {% else %}
      <div class="small">No new roles this week.</div>
      {% endif %}
    </div>
  {% endfor %}
  {% endif %}

  <div class="section-title">🔥 Top matches this week</div>
  {% for c in top %}
    <div class="card">
      <span class="score {% if c.highlighted %}hi{% endif %}">{{ c.score }}</span>
      <span class="rank">#{{ loop.index }}</span>
      <span class="name">{{ c.name }}</span>
      <div class="meta">
        {% if c.stage %}<span class="tag stage">{{ c.stage|title }}</span>{% endif %}
        {% if c.amount %}<span class="small">{{ c.amount }}</span>{% endif %}
        {% for d in c.domains %}<span class="tag dom">{{ d }}</span>{% endfor %}
        {% if c.ai_signal %}<span class="tag ai">AI</span>{% endif %}
      </div>
      {% if c.investors %}<div class="small">Investors: {{ c.investors|join(', ') }}</div>{% endif %}
      {% if c.blurb %}<div class="blurb">{{ c.blurb|truncate(220) }}</div>{% endif %}
      {% if c.matched_jobs %}
      <ul class="jobs">
        {% for j in c.matched_jobs %}
        <li>✅ <a href="{{ j.url }}">{{ j.title }}</a> <span class="small">· {{ j.matched_role }} · {{ j.location }}</span></li>
        {% endfor %}
      </ul>
      {% elif c.suggest_watch %}
      <div class="small">No matching roles yet — hiring often lags funding 2–3 weeks. Suggested for your watchlist.</div>
      {% endif %}
      {% if c.urls %}<div class="small"><a href="{{ c.urls[0] }}">Source ↗</a></div>{% endif %}
    </div>
  {% endfor %}

  {% if suggested %}
  <div class="section-title">👀 Worth watching (good fit, no roles yet)</div>
  {% for c in suggested %}
    <div class="card">
      <span class="score {% if c.highlighted %}hi{% endif %}">{{ c.score }}</span>
      <span class="name">{{ c.name }}</span>
      <div class="meta">
        {% if c.stage %}<span class="tag stage">{{ c.stage|title }}</span>{% endif %}
        {% for d in c.domains %}<span class="tag dom">{{ d }}</span>{% endfor %}
        {% if c.ai_signal %}<span class="tag ai">AI</span>{% endif %}
      </div>
    </div>
  {% endfor %}
  {% endif %}

  <div class="footer">
    seed-summary · sources: {{ sources|join(', ') }}<br>
    Tune your roles, domains &amp; weights in <code>config/profile.yml</code>.
  </div>
</div>
</body>
</html>
